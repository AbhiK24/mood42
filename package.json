{
  "name": "mood42",
  "version": "2.0.0",
  "type": "module",
  "description": "mood42 - agentic tv | AI-programmed ambient channels",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && uvicorn main:app --reload --port 3000",
    "build": "vite build && cp index.html dist/index.html",
    "preview": "vite preview",
    "start": "cd server && uvicorn main:app --host 0.0.0.0 --port ${PORT:-3000}",
    "start:static": "npx serve dist -l $PORT"
  },
  "keywords": [
    "generative",
    "art",
    "animation",
    "pixi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbhiK24/mood42.git"
  },
  "dependencies": {
    "gsap": "^3.14.2",
    "pixi.js": "^8.17.1"
  },
  "devDependencies": {
    "terser": "^5.46.1",
    "vite": "^5.4.11"
  }
}
